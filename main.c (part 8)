void draw_player(void) {
    LPUART_cursor(pRow, pCol);      // move cursor to player location
    LPUART_ESC_print("[32m");       // set text to green
    LPUART_print("P");              // draw the player character
    LPUART_ESC_print("[0m");        // reset color so border stays white
}

