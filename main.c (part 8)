#include "main.h"
#include "lpuart.h"

//game area boundaries
#define G_TOP 		2		//top border row
#define G_BOT 		20		//bottom border row
#define G_LEFT 		2		//left border column
#define G_RIGHT 	60 		//right border column

//game state at the start (start at center)
volatile uint8_t pRow 	= 11;
volatile uint8_t pCol 	= 31;
volatile uint8_t gameOn	= 0;


void SystemClock_Config(void);
void draw_border(void);
void draw_player(void);

int main(void) {

	HAL_Init();
	SystemClock_Config();
	LPUART_init();

	LPUART_ESC_print("[2J");      // clear screen
	LPUART_ESC_print("[?25l");      // hide blinking cursor

	// print decorative top border of splash
	LPUART_cursor(8, 18);           // position cursor row 8, col 18
	LPUART_ESC_print("[35m");       // set text color to purple
	LPUART_print("*.,'*.,'*.,'*.,'*.,'*.,'*.,");

	LPUART_cursor(9, 18);
	LPUART_ESC_print ("[33m"); //yellow
	LPUART_print("'.,*'.,*'.,*'.,*'.,*'.,*'.,*");


	// print game title line 1
	LPUART_cursor(10, 22);          // position for first word
	LPUART_ESC_print("[31m");       // set text color to blue
	LPUART_print("B O U N D A R Y");

	// print game title line 2
	LPUART_cursor(12, 24);          // position for second word (indented)
	LPUART_ESC_print("[31m");       // set text color to blue
	LPUART_print("R U N N E R");

	// print decorative bottom border of splash
	LPUART_cursor(13, 18);
	LPUART_ESC_print("[36m");       // cyan
	LPUART_print("'.,*'.,*'.,*'.,*'.,*'.,*'.,*");

	LPUART_cursor(14, 18);
	LPUART_ESC_print("[32m"); //green
	LPUART_print("'.,*'.,*'.,*'.,*'.,*'.,*'.,*");

	// print control instructions
	LPUART_cursor(16, 22);
	LPUART_ESC_print("[37m");       // white text
	LPUART_print("IJKL to move");

	// busy-wait ~5 seconds at 4 MHz clock
	for (volatile uint32_t d = 0; d < 2000000; d++) ;

	LPUART_ESC_print("[0m");        // reset all text attributes (color, blink)
	LPUART_ESC_print("[2J");        // clear screen for the game
	draw_border();                  // draw the rectangular border
	draw_player();                  // places character in the center

	gameOn = 1;                     // allow the ISR to process movement keys

	while (1) {
	        ;  // nothing here — all input handled by the receive interrupt
	}
}
//draw rectangular border
void draw_border(void) {
    int i;

    // draw top row and bottom row with dashes
    for (i = G_LEFT; i <= G_RIGHT; i++) {
        LPUART_cursor(G_TOP, i);    // move to top row, column i
        LPUART_print("-");
        LPUART_cursor(G_BOT, i);    // move to bottom row, column i
        LPUART_print("-");
    }

    // draw left column and right column with pipes
    for (i = G_TOP; i <= G_BOT; i++) {
        LPUART_cursor(i, G_LEFT);   // move to row i, left edge
        LPUART_print("|");
        LPUART_cursor(i, G_RIGHT);  // move to row i, right edge
        LPUART_print("|");
    }

    // overwrite the four corners with '+' for a cleaner look
    LPUART_cursor(G_TOP, G_LEFT);   LPUART_print("|");
    LPUART_cursor(G_TOP, G_RIGHT);  LPUART_print("|");
    LPUART_cursor(G_BOT, G_LEFT);   LPUART_print("|");
    LPUART_cursor(G_BOT, G_RIGHT);  LPUART_print("|");
}
