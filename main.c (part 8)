/**
 * @brief  This function is executed in case of error occurrence.
 * @retval None
 */
void Error_Handler(void) {
	__disable_irq();
	while (1) {
	}
}

void LPUART1_IRQHandler(void) {
    uint8_t charRecv;
    if (LPUART1->ISR & USART_ISR_RXNE) {
        charRecv = LPUART1->RDR;

        // --- game movement (only active after splash screen) ---
        if (gameOn) {
            erase_player();

            switch (charRecv) {
            case 'i': case 'I': //up
                pRow--;
                if (pRow - 1 <= G_TOP) pRow = G_BOT - 2;
                break;
            case 'k': case 'K': //down
                pRow++;
                if (pRow + 1 >= G_BOT) pRow = G_TOP + 2;
                break;
            case 'j': case 'J': //left
                pCol--;
                if (pCol - 1 <= G_LEFT) pCol = G_RIGHT - 2;
                break;
            case 'l': case 'L': //right
                pCol++;
                if (pCol + 1 >= G_RIGHT) pCol = G_LEFT + 2;
                break;
            default:
                break;
            }

            draw_player();
            return;                     // skip the old echo/color logic
        }
    }
}

